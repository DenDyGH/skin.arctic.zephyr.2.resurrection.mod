    <!-- Power Menu -->
    <menu name="powermenu" controltype="button">
        <defaults>
            <skinshortcuts include="Defs_Context_Button" />
        </defaults>
        <allow widgets="false" backgrounds="false" submenus="false"/>
        <item name="button-quit" visible="System.ShowExitButton">
            <label>$LOCALIZE[13012]</label>
            <action>Quit()</action>
            <visible>System.ShowExitButton</visible>
            <icon>special://skin/extras/icons/power.png</icon>
        </item>
        <item name="button-shutdown" visible="System.CanPowerDown">
            <label>$LOCALIZE[13016]</label>
            <action>Powerdown()</action>
            <visible>System.CanPowerDown</visible>
            <icon>special://skin/extras/icons/power.png</icon>
        </item>
        <item name="button-suspend" visible="System.CanSuspend">
            <label>$LOCALIZE[13011]</label>
            <onclick>Dialog.Close(shutdownmenu)</onclick>
            <action>Suspend()</action>
            <visible>System.CanSuspend</visible>
            <icon>special://skin/extras/icons/power.png</icon>
        </item>
        <item name="button-hibernate" visible="System.CanHibernate">
            <label>$LOCALIZE[13010]</label>
            <onclick>Dialog.Close(shutdownmenu)</onclick>
            <action>Hibernate()</action>
            <visible>System.CanHibernate</visible>
            <icon>special://skin/extras/icons/power.png</icon>
        </item>
        <item name="button-reboot" visible="System.CanReboot">
            <label>$LOCALIZE[13013]</label>
            <action>Reset()</action>
            <visible>System.CanReboot</visible>
            <icon>special://skin/extras/icons/power.png</icon>
        </item>
        <item name="button-rebootfromnand" visible="System.HasAddon(service.libreelec.settings) | System.HasAddon(service.coreelec.settings)">
            <label>$LOCALIZE[31599]</label>
            <action>System.ExecWait("/usr/sbin/rebootfromnand")</action>
            <action>Reboot()</action>
            <visible>System.HasAddon(service.libreelec.settings) | System.HasAddon(service.coreelec.settings)</visible>
            <icon>special://skin/extras/icons/android.png</icon>
        </item>
        <item name="button-logoff" visible="System.Loggedon + [System.HasLoginScreen | Integer.IsGreater(System.ProfileCount,1)]">
            <label>$LOCALIZE[20126]</label>
            <label2>$INFO[system.profilename]</label2>
            <onclick>dialog.close(all,true)</onclick>
            <action>System.LogOff</action>
            <visible>System.Loggedon + [System.HasLoginScreen | Integer.IsGreater(System.ProfileCount,1)]</visible>
            <icon>special://skin/extras/icons/power.png</icon>
        </item>
        <item name="button-masterunlock" visible="System.HasLocks">
            <label>$LOCALIZE[20046]</label>
            <action>Mastermode</action>
            <visible>System.HasLocks + System.IsMaster</visible>
            <icon>special://skin/extras/icons/power.png</icon>
        </item>
        <item name="button-masterlock" visible="System.HasLocks">
            <label>$LOCALIZE[20045]</label>
            <action>Mastermode</action>
            <visible>System.HasLocks + !System.IsMaster</visible>
            <icon>special://skin/extras/icons/power.png</icon>
        </item>
        <item name="button-inhibit-on" visible="System.HasShutdown">
            <label>$LOCALIZE[13017]</label>
            <action>InhibitIdleShutdown(true)</action>
            <visible>System.HasShutdown + !System.IdleShutdownInhibited</visible>
            <icon>special://skin/extras/icons/power.png</icon>
        </item>
        <item name="button-inhibit-off" visible="System.HasShutdownSystem.HasShutdown">
            <label>$LOCALIZE[13018]</label>
            <action>InhibitIdleShutdown(false)</action>
            <visible>System.HasShutdown + System.IdleShutdownInhibited</visible>
            <icon>special://skin/extras/icons/power.png</icon>
        </item>
        <item name="button-settings" required="true">
            <label>$LOCALIZE[5]</label>
            <action>Dialog.Close(all,true)</action>
            <action>ActivateWindow(Settings)</action>
            <icon>special://skin/extras/icons/power.png</icon>
        </item>
